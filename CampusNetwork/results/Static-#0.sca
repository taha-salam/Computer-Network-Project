config *.bbaRouter.routeTable "\"0.0.0.0/0.0.0.0:0;10.0.6.0/255.255.255.0:0\""
config *.adminRouter.routeTable "\"0.0.0.0/0.0.0.0:0;10.0.6.0/255.255.255.0:0\""
config network CampusNetwork
config sim-time-limit 180s
config record-eventlog false
config debug-on-errors false
config **.vector-recording false
config **.scalar-recording true
config **.app[0].sendInterval 0.05s
config *.scenarioManager.script "xml(\"<script><at t='60.0'><set-param submodule='coreRouter.ethg[0].channel' name='disabled' value='true'/><set-param submodule='seRouter.ethg[0].channel' name='disabled' value='true'/></at><at t='120.0'><set-param submodule='coreRouter.ethg[0].channel' name='disabled' value='false'/><set-param submodule='seRouter.ethg[0].channel' name='disabled' value='false'/></at></script>\")"
config **.seHost*.app[0].typename TrafficGenerator
config **.eeHost*.app[0].typename TrafficGenerator
config **.bbaHost*.app[0].typename TrafficGenerator
config **.adminHost*.app[0].typename TrafficGenerator
config *.appServer.app[0].typename UdpSink
config *.appServer.app[0].localPort 1234
config **.app[0].trafficProfile "\"CBR\""
config **.app[0].destAddress "\"10.0.6.1\""
config **.app[0].destPort 1234
config **.app[0].startTime 1s
config **.app[0].stopTime 175s
config **.app[0].packetSize 512

