config image-path ../inet4.5/images
config description "Static Routing"
config extends General
config *.coreRouter.typename StaticRouter
config *.seRouter.typename StaticRouter
config *.eeRouter.typename StaticRouter
config *.bbaRouter.typename StaticRouter
config *.adminRouter.typename StaticRouter
config *.coreRouter.numPorts 6
config *.seRouter.numPorts 4
config *.eeRouter.numPorts 4
config *.bbaRouter.numPorts 4
config *.adminRouter.numPorts 4
config *.coreRouter.ipAddress "\"10.0.10.1\""
config *.seRouter.ipAddress "\"10.0.10.2\""
config *.eeRouter.ipAddress "\"10.0.10.6\""
config *.bbaRouter.ipAddress "\"10.0.10.10\""
config *.adminRouter.ipAddress "\"10.0.10.14\""
config *.coreRouter.routeTable "\"10.0.1.0/255.255.255.0:0;10.0.2.0/255.255.255.0:1;10.0.3.0/255.255.255.0:2;10.0.4.0/255.255.255.0:3;10.0.6.0/255.255.255.0:5\""
config *.seRouter.routeTable "\"0.0.0.0/0.0.0.0:0;10.0.6.0/255.255.255.0:0\""
